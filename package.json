{
  "name": "google-forms-lite",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:client": "pnpm --filter client run dev",
    "dev:server": "pnpm --filter server run dev:server",
    "build": "pnpm --filter server build && pnpm --filter client build",
    "start:prod": "pnpm --filter server start:prod"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ]
}